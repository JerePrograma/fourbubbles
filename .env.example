# Docker Compose project isolation and host-published ports.
COMPOSE_PROJECT_NAME=fourbubbles
POSTGRES_HOST_PORT=5432
BACKEND_HOST_PORT=8081
FRONTEND_HOST_PORT=8080

# PostgreSQL and backend credentials. Start-Local.ps1 replaces placeholders
# only when creating .env; existing values are never overwritten.
POSTGRES_DB=ropalista
POSTGRES_USER=ropalista
POSTGRES_PASSWORD=change-me
DB_HOST=postgres
DB_PORT=5432
DB_NAME=ropalista
DB_USER=ropalista
DB_PASSWORD=change-me

JWT_SECRET_BASE64=REPLACE_WITH_AT_LEAST_32_RANDOM_BYTES_ENCODED_AS_BASE64
JWT_ACCESS_TTL=PT15M
REFRESH_TOKEN_TTL=P30D
LOGIN_MAX_ATTEMPTS=5
LOGIN_ATTEMPT_WINDOW=PT15M
LOGIN_BLOCK_DURATION=PT15M
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080
APP_TIME_ZONE=America/Argentina/Buenos_Aires
APP_DEV_ADMIN_USERNAME=admin
APP_DEV_ADMIN_PASSWORD=change-me-now
VITE_API_BASE_URL=/api
